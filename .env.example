#  REQUIRED 
# GitLab personal access token (api scope)
GITLAB_TOKEN=
# Secret string matching your GitLab webhook config
GITLAB_WEBHOOK_SECRET=
# From your GitLab OAuth application
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_BASE_URL=https://gitlab.com
GITLAB_MCP_SERVER_URL=https://gitlab.com/-/mcp

# Anthropic Claude API key
ANTHROPIC_API_KEY=

# PostgreSQL connection string (Supabase or local)
DATABASE_URL=

# NextAuth  use any random 32-char string locally
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

#  OPTIONAL (chaos execution requires GKE) 
# Leave these as dummy strings for local testing without GKE
GOOGLE_CLOUD_PROJECT_ID=optional-fill-for-gke
GOOGLE_CLOUD_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=optional-fill-for-gke
GKE_CLUSTER_NAME=vorth-chaos-cluster
GKE_CLUSTER_ZONE=us-central1-a
VERTEX_AI_LOCATION=us-central1

#  OPTIONAL (tuning) 
WEBHOOK_SERVER_PORT=3001
WEBHOOK_SERVER_URL=http://localhost:3001
MIN_RESILIENCE_SCORE=70
MAX_EXPERIMENTS_PER_MR=5
CHAOS_EXPERIMENT_TIMEOUT_SECONDS=120
