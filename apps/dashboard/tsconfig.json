{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "es2022"
    ],
    "allowJs": false,
    "incremental": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@vorth/shared-types": [
        "packages/shared-types/src/index.ts"
      ],
      "@vorth/gitlab-client": [
        "packages/gitlab-client/src/index.ts"
      ],
      "@vorth/mcp-tools": [
        "packages/mcp-tools/src/index.ts"
      ],
      "@vorth/diff-analyzer": [
        "agents/diff-analyzer/src/index.ts"
      ],
      "@vorth/hypothesis-engine": [
        "agents/hypothesis-engine/src/index.ts"
      ],
      "@vorth/chaos-runner": [
        "agents/chaos-runner/src/index.ts"
      ],
      "@vorth/results-analyzer": [
        "agents/results-analyzer/src/index.ts"
      ],
      "@vorth/fix-writer": [
        "agents/fix-writer/src/index.ts"
      ],
      "@vorth/deploy-gate": [
        "agents/deploy-gate/src/index.ts"
      ],
      "@/*": [
        "apps/dashboard/*"
      ]
    },
    "noEmit": true,
    "isolatedModules": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
